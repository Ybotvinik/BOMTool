# Backend configuration (copy to .env for local non-Docker runs).
DATABASE_URL=postgresql+psycopg2://glintech:glintech@localhost:5432/glintech
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FILE_STORAGE_BACKEND=local
LOCAL_STORAGE_DIR=/data/uploads

# Official supplier API pricing (customer-safe reference only)
# Set SUPPLIER_API_MOCK=false for real Digi-Key / Mouser API calls.
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=
DIGIKEY_ENV=sandbox
MOUSER_API_KEY=
SUPPLIER_API_TIMEOUT_SECONDS=20
SUPPLIER_API_MAX_RETRIES=2
SUPPLIER_API_MOCK=false
SUPPLIER_API_MOCK_ALLOW_EXPORT=false
