# Copy to .env.aws on the AWS server. Do not commit .env.aws.
#
# PUBLIC_HOST = EC2 public IPv4 or DNS name (no http://, no port)
# Example: 3.120.45.67  or  ec2-3-120-45-67.eu-west-1.compute.amazonaws.com

PUBLIC_HOST=YOUR_EC2_PUBLIC_IP_OR_DNS

POSTGRES_USER=glintech
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=glintech

# Docker image tag for alpha releases
IMAGE_TAG=alpha
APP_ENV=alpha

# Host ports (security group must allow these)
FRONTEND_PORT=3000
BACKEND_PORT=8000
